# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Groq
GROQ_API_KEY=

# Apollo.io (lead scraping)
APOLLO_API_KEY=

# Hunter.io (email finder)
HUNTER_API_KEY=

# Apify (LinkedIn lead scraping via harvestapi~linkedin-people-search actor)
APIFY_API_KEY=

# Snov.io (email prospecting by domain)
SNOV_CLIENT_ID=your_snov_client_id
SNOV_CLIENT_SECRET=your_snov_client_secret

# Serper.dev (Google Search API for prospecting)
SERPER_API_KEY=your_serper_api_key

# Nodemailer (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Apex Lead Gen

# App URL (used for tracking pixel absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
